generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Currency {
  PEN
  USD
}

enum UserRole {
  ADMIN
  ADVISOR
}

enum RateType {
  EFFECTIVE_ANNUAL
  NOMINAL_ANNUAL
}

enum CapitalizationFrequency {
  ANNUAL
  SEMIANNUAL
  QUARTERLY
  BIMONTHLY
  MONTHLY
  DAILY_360
}

enum VehicleStatus {
  AVAILABLE
  FINANCED
  INACTIVE
}

enum VehicleCondition {
  NUEVO
  SEMINUEVO
}

enum FinancialProductCostType {
  DEBT_RELIEF_INSURANCE
  VEHICLE_INSURANCE
  PERIODIC_COMMISSION
  ITF
  OTHER
}

enum CostCalculationType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum CostCalculationBase {
  BALANCE
  VEHICLE_PRICE
  PAYMENT_AMOUNT
  FINANCED_AMOUNT
  FIXED
}

enum SimulationStatus {
  DRAFT
  CALCULATED
  APPROVED
  ARCHIVED
}

enum GracePeriodType {
  TOTAL
  PARTIAL
}

enum PaymentPeriodType {
  NORMAL
  TOTAL_GRACE
  PARTIAL_GRACE
}

model User {
  id                String             @id @default(cuid())
  username          String             @unique
  passwordHash      String
  role              UserRole           @default(ADVISOR)
  active            Boolean            @default(true)
  sessions          Session[]
  creditSimulations CreditSimulation[]
  auditLogs         AuditLog[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([role])
  @@index([active])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expiresAt    DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Client {
  id             String             @id @default(cuid())
  dni            String             @unique
  firstNames     String
  lastNames      String
  email          String
  phone          String?
  address        String?
  birthDate      DateTime?
  occupation     String?
  monthlyIncome  Decimal            @db.Decimal(18, 8)
  incomeCurrency Currency
  active         Boolean            @default(true)
  simulations    CreditSimulation[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([email])
  @@index([active])
  @@index([lastNames, firstNames])
}

model Vehicle {
  id          String             @id @default(cuid())
  vin         String             @unique
  brand       String
  model       String
  year        Int
  color       String?
  type        String?
  condition   VehicleCondition
  price       Decimal            @db.Decimal(18, 8)
  currency    Currency
  status      VehicleStatus      @default(AVAILABLE)
  simulations CreditSimulation[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([brand, model])
  @@index([status])
  @@index([currency])
}

model FinancialProduct {
  id                         String                 @id @default(cuid())
  name                       String
  currency                   Currency
  defaultDownPaymentRate     Decimal                @db.Decimal(18, 12)
  defaultResidualValueRate   Decimal                @db.Decimal(18, 12)
  defaultTermMonths          Int
  defaultRateType            RateType
  defaultAnnualRate          Decimal                @db.Decimal(18, 12)
  capitalization             CapitalizationFrequency?
  cok                        Decimal                @db.Decimal(18, 12)
  active                     Boolean                @default(true)
  costs                      FinancialProductCost[]
  simulations                CreditSimulation[]
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt

  @@unique([name, currency])
  @@index([currency, active])
}

model FinancialProductCost {
  id              String                   @id @default(cuid())
  productId       String
  costType        FinancialProductCostType
  calculationType CostCalculationType
  rate            Decimal?                 @db.Decimal(18, 12)
  fixedAmount     Decimal?                 @db.Decimal(18, 8)
  calculationBase CostCalculationBase
  product         FinancialProduct         @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@unique([productId, costType])
  @@index([productId])
  @@index([costType])
}

model CreditSimulation {
  id                             String                @id @default(cuid())
  createdByUserId                String
  clientId                       String
  vehicleId                      String
  financialProductId             String
  inputSnapshot                  Json
  calculatedMonthlyEffectiveRate Decimal               @db.Decimal(18, 12)
  financedAmount                 Decimal               @db.Decimal(18, 8)
  balloonPayment                 Decimal               @db.Decimal(18, 8)
  basePayment                    Decimal               @db.Decimal(18, 8)
  status                         SimulationStatus      @default(CALCULATED)
  simulatedAt                    DateTime              @default(now())
  createdAt                      DateTime              @default(now())
  updatedAt                      DateTime              @updatedAt
  createdByUser                  User                  @relation(fields: [createdByUserId], references: [id])
  client                         Client                @relation(fields: [clientId], references: [id])
  vehicle                        Vehicle               @relation(fields: [vehicleId], references: [id])
  financialProduct               FinancialProduct      @relation(fields: [financialProductId], references: [id])
  gracePeriods                   GracePeriod[]
  paymentScheduleItems           PaymentScheduleItem[]
  financialIndicator             FinancialIndicator?

  @@index([createdByUserId])
  @@index([clientId])
  @@index([vehicleId])
  @@index([financialProductId])
  @@index([status])
  @@index([simulatedAt])
}

model GracePeriod {
  id           String           @id @default(cuid())
  simulationId String
  type         GracePeriodType
  periodFrom   Int
  periodTo     Int
  simulation   CreditSimulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())

  @@index([simulationId])
  @@unique([simulationId, periodFrom, periodTo])
}

model PaymentScheduleItem {
  id                    String            @id @default(cuid())
  simulationId          String
  periodNumber          Int
  periodType            PaymentPeriodType
  openingBalance        Decimal           @db.Decimal(18, 8)
  interest              Decimal           @db.Decimal(18, 8)
  basePayment           Decimal           @db.Decimal(18, 8)
  amortization          Decimal           @db.Decimal(18, 8)
  debtReliefInsurance   Decimal           @db.Decimal(18, 8)
  vehicleInsurance      Decimal           @db.Decimal(18, 8)
  commission            Decimal           @db.Decimal(18, 8)
  itf                   Decimal           @db.Decimal(18, 8)
  balloonPayment        Decimal           @db.Decimal(18, 8)
  totalPayment          Decimal           @db.Decimal(18, 8)
  closingBalance        Decimal           @db.Decimal(18, 8)
  debtorCashFlow        Decimal           @db.Decimal(18, 8)
  simulation            CreditSimulation  @relation(fields: [simulationId], references: [id], onDelete: Cascade)

  @@unique([simulationId, periodNumber])
  @@index([simulationId])
  @@index([periodType])
}

model FinancialIndicator {
  id              String           @id @default(cuid())
  simulationId    String           @unique
  netPresentValue Decimal          @db.Decimal(18, 8)
  monthlyIrr      Decimal          @db.Decimal(18, 12)
  annualIrr       Decimal          @db.Decimal(18, 12)
  tcea            Decimal          @db.Decimal(18, 12)
  totalInterest   Decimal          @db.Decimal(18, 8)
  totalCharges    Decimal          @db.Decimal(18, 8)
  totalPaid       Decimal          @db.Decimal(18, 8)
  simulation      CreditSimulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  createdAt       DateTime         @default(now())

  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  recordId  String
  detail    Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, recordId])
  @@index([createdAt])
}
